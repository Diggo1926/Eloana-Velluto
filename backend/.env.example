# Banco de dados PostgreSQL (Railway provê automaticamente)
DATABASE_URL=

# Chave secreta para JWT — gere com: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=

# Origem permitida no CORS (URL do seu frontend, ex: https://usuario.github.io)
ALLOWED_ORIGIN=

# Ambiente: development | production
FLASK_ENV=production

# Credenciais do único usuário administrador
ADMIN_USER=eloana
# Hash bcrypt da senha — gere com: python -c "import bcrypt; print(bcrypt.hashpw(b'sua_senha', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=
